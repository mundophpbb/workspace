{
    "name": "mundophpbb/workspace",
    "type": "phpbb-extension",
    "description": "phpBB Workspace IDE - A full-featured virtual IDE to manage projects, write code, and organize files directly within the forum panel.",
    "homepage": "https://github.com/mundophpbb/workspace",
    "version": "1.0.0",
    "time": "2026-02-13",
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "Chico Gois",
            "homepage": "https://mundophpbb.com.br",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=7.4",
        "composer/installers": "^1.0 || ^2.0"
    },
    "autoload": {
        "psr-4": {
            "mundophpbb\\workspace\\": ""
        }
    },
    "extra": {
        "display-name": "phpBB Workspace IDE",
        "soft-require": {
            "phpbb/phpbb": ">=3.3.0"
        },
        "version-check": {
    "host": "mundophpbb.com.br",
    "directory": "/ext/",
    "filename": "workspace.json",
    "ssl": true
}
    }
}